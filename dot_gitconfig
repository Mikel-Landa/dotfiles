[user]
	name = Mikel Landa
	useConfigOnly = true
	signingkey = 7C906F517916F1BB
	
[url "git@github.com:"]
	insteadOf = "gh:"

[column]
	ui = auto

[branch]
	sort = -committerdate

[tag]
	sort = version:refname

[help]
	autoCorrect = prompt

[status]
	branch = true
	showStash = true
  
[init]
	defaultBranch = main
	
[pull]
	rebase = true
	
[commit]
	gpgsign = true
  
[push]
	default = simple
	autoSetupRemote = true
	useForceIfIncludes = true
	followTags = true
	
[fetch]
	prune = true
	
[rerere]
	enabled = true
	autoupdate = true

[merge]
	# (just 'diff3' if git version < 2.3)
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	colorMoved = zebra
	mnemonicPrefix = true
	renames = true
	external = difft

[include]
    path = ~/.gitconfig-personal

[includeIf "gitdir:~/repos/"]
    path = ~/.gitconfig-work

[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true

[core]
	excludesfile = ~/.gitignore

[alias]
	root = rev-parse --show-toplevel
