# shellcheck shell=bash
# This is my .profile, sourced by every shell:
#   zsh: via ~/.zshenv
#   bash (login): direct
#   bash (interactive non-login): via ~/.bashrc
#   sh: direct
#

# PATH helpers — must be defined before any path_push call below.
[ -r "$HOME/.config/shell/path.sh" ] && . "$HOME/.config/shell/path.sh"

# Locale.
export LC_ALL=en_US.UTF-8

# Editors / pager.
export VISUAL=nvim
export EDITOR=nvim
export ED=nvim
export PAGER=less
export LESS='-n -i -g -q -R -X -K -F'

# Git.
export GIT_DISCOVERY_ACROSS_FILESYSTEM=0

# Skip tty fork in non-interactive shells (scripts, pipes).
if [ -t 0 ]; then
    export GPG_TTY=$(tty 2>/dev/null || echo not-a-tty)
else
    export GPG_TTY=not-a-tty
fi

# ---------- XDG base directories ----------
# Centralizes config/cache/data locations
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

#### CARGO ####
# Cargo disk-space defaults (applies to all cargo invocations).
# - line-tables-only: keep backtrace symbols, drop step-debug info. ~40-60% smaller target/.
# - split-debuginfo=unpacked: faster relink on Linux; debug info as separate files.
# Override per-project via Cargo.toml [profile.dev] if a full debugger session is needed.
export CARGO_PROFILE_DEV_DEBUG=line-tables-only
export CARGO_PROFILE_DEV_SPLIT_DEBUGINFO=unpacked

# sccache cache cap (default 10G, bumped for multi-sibling rust workloads).
export SCCACHE_CACHE_SIZE=30G

# Shared target dir: ALL repos write compiled deps to one location so siblings
# reuse each other's builds (dedup + faster cross-repo builds). Combined with
# the sccache rustc-wrapper (~/.cargo/config.toml) this is the cross-workspace
# lib-sharing layer. Per-project `target/` is bypassed when this is set.
# CARGO_INCREMENTAL intentionally left ON (default) — keeps fast edit-loop
# rebuilds; sccache still shares all dependency compilations regardless.
export CARGO_TARGET_DIR="$HOME/.cache/cargo-target/shared"

##### GO ####
# Explicit set so mise doesn't override
export GOPATH=$HOME/go
export GOBIN=$HOME/go/bin
export GO111MODULE=on

# mise.
export MISE_DEFAULT_CONFIG_FILENAME='.mise.local.toml'

# CLAUDE
# Compact at 30% of window (Currently 300k)
export CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=30

# PATH. Lower-priority paths pushed to back; higher-priority pushed to front.
path_push_back /sbin
path_push_back /usr/sbin
path_push "$HOME/.local/bin"
path_push "$HOME/bin"
path_push "$GOBIN"
path_push "$HOME/.cargo/bin"
# mise shims expose mise-managed tools (node, python, etc.) to non-interactive
# shells (scripts) without needing `mise activate` to run.
path_push "$HOME/.local/share/mise/shims"
# Fallback nvim if mise doesn't have one installed. Pushed to back so mise wins.
[ -d /opt/nvim/bin ] && path_push_back /opt/nvim/bin

# vim: ft=sh
