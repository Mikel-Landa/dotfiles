spawn-sh-at-startup "wl-paste --watch cliphist store &"

// Stash workspace daemon — must run for niri-scratchpad target/create to work.
spawn-at-startup "niri-scratchpad" "daemon"

spawn-at-startup "brave" "--class=brave-startup"

spawn-at-startup "t3"

spawn-at-startup "kitty" "--class=kitty-term"

