[user]
	name = Mikel Landa
	useConfigOnly = true
	signingkey = 7C906F517916F1BB
	
[url "git@github.com:Mikel-Landa/"]
	insteadOf = "ml:"

[url "git@github.com:"]
	insteadOf = "gh:"

[column]
	ui = auto

[branch]
	sort = -committerdate

[tag]
	sort = version:refname

[help]
	autoCorrect = prompt

[status]
	branch = true
	showStash = true
  
[init]
	defaultBranch = main
	
[pull]
	rebase = true
	
[commit]
	gpgsign = true
  
[push]
	default = simple
	autoSetupRemote = true
	useForceIfIncludes = true
	followTags = true
	
[fetch]
	prune = true
	
[rerere]
	enabled = true
	autoupdate = true

[merge]
	# (just 'diff3' if git version < 2.3)
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	colorMoved = zebra
	mnemonicPrefix = true
	renames = true

[include]
    path = ~/.config/git/config-personal

[include]
    path = ~/.config/git/config-work

[includeIf "gitdir:~/personal/"]
    path = ~/.config/git/config-personal

[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true

[alias]
	wt = worktree
	root = rev-parse --show-toplevel
	
	# `git log` with patches shown with difftastic.
	dl = -c diff.external=difft log -p --ext-diff

	# Show the most recent commit with difftastic.
	ds = -c diff.external=difft show --ext-diff

	# `git diff` with difftastic.
	df = -c diff.external=difft diff
[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE
