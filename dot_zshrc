#!/usr/bin/env zsh

##PROFILE ZSH
# zmodload zsh/zprof

# Auto-attach tmux via sesh + fzf picker for fresh interactive shells.
# Must run before p10k instant prompt — picker takes over the screen.
# Skips: already in tmux, IDE-embedded shells, agent shells, non-interactive.
# Source order: tmux, config, zoxide — each `sesh list` is called separately so
# the awk dedupe (strip coloured-icon prefix, keep first) controls priority.
if [[ $- == *i* && -z "$TMUX" && -z "$CLAUDECODE" && -z "$VSCODE_INJECTION" \
      && -z "$INTELLIJ_ENVIRONMENT_READER" && -z "$NVIM" ]] \
   && command -v sesh >/dev/null 2>&1 && command -v fzf >/dev/null 2>&1; then
    _sesh_pick=$({ sesh list -i -t; sesh list -i -c; sesh list -i -z; } \
        | awk '{ k=$0; sub(/^[^ ]+ +/,"",k); if (!seen[k]++) print }' \
        | fzf --ansi --no-sort --height 20 --reverse \
              --prompt '⚡  ' --header 'sesh: pick a session' \
        | sed -E $'s/\x1b\\[[0-9;]*[a-zA-Z]//g; s/^[^ ]+ +//')
    [[ -n "$_sesh_pick" ]] && exec sesh connect "$_sesh_pick"
    unset _sesh_pick
fi

# Powerlevel10k instant prompt. Must stay near top — before anything that
# produces output. Sources cached prompt to render before plugins finish.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Skip rest for non-interactive shells (cron, ssh-cmd, scripts).
# Env, PATH, and locale live in ~/.profile (sourced via ~/.zshenv).
[[ -o interactive ]] || return

setopt vi  # If EDITOR is set to vim, we have this for free
KEYTIMEOUT=1                # snappy <Esc> in vi mode
setopt interactive_comments # allow for comments in interactive shells
setopt autocd               # `dir` instead of `cd dir`
setopt nobeep               # no terminal bell
setopt numeric_glob_sort    # file10 sorts after file9, not after file1
typeset -U path PATH        # dedup PATH; future appends become idempotent


export ZSH_EVALCACHE_DIR=${ZSH_EVALCACHE_DIR:-"$HOME/.zsh-evalcache"}

# Source all the things ✨ — cache sheldon's generated script
_sheldon_cache="${XDG_CACHE_HOME:-$HOME/.cache}/sheldon.zsh"
_sheldon_cfg="${XDG_CONFIG_HOME:-$HOME/.config}/sheldon/plugins.toml"
if [[ ! -s $_sheldon_cache || $_sheldon_cfg -nt $_sheldon_cache ]]; then
    mkdir -p ${_sheldon_cache:h}
    sheldon source >| $_sheldon_cache
    zcompile -R -- $_sheldon_cache.zwc $_sheldon_cache 2>/dev/null
fi
source $_sheldon_cache
unset _sheldon_cache _sheldon_cfg

ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=253"
# Async + buffer cap keep input lag flat on long lines.
ZSH_AUTOSUGGEST_USE_ASYNC=1
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20
ZSH_AUTOSUGGEST_STRATEGY=(history)

## Characters included **will** be considered part of the word
WORDCHARS='*?_-.[]~=&;!#$%^(){}<>'

# Local secrets (Atlas tokens, etc.). Not managed by chezmoi.
[[ -r ~/.config/zsh/secrets.zsh ]] && source ~/.config/zsh/secrets.zsh

# Powerlevel10k user config.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

##PROFILE ZSH
# zprof
